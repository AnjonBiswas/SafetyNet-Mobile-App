{
  "expo": {
    "name": "SafetyNet Mobile",
    "slug": "safetynet-mobile",
    "version": "1.0.0",
    "sdkVersion": "50.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FFE5F1",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safetynet.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFE5F1"
      },
      "package": "com.safetynet.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {},
    "plugins": [
      "expo-location",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SafetyNet to access your camera to record emergency videos and scan QR codes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SafetyNet to access your photos to attach evidence to reports.",
          "cameraPermission": "Allow SafetyNet to access your camera to take photos for reports."
        }
      ],
      "expo-font"
    ]
  }
}